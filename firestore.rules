rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definition
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // 2. Validation Blueprints
    function isValidUserConfig(data) {
      // Very loose check because it's dynamic user configuration
      return true;
    }

    function isAuthorized() {
      return isSignedIn() && exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email.lower()));
    }

    // Master list of collections
    // Only authorized users can interact with any data
    
    match /authorized_users/{email} {
      // Only the Firebase console owner or an already authorized admin can manage this
      // For now, let's allow read if signed in (to check self), but write only via console
      allow get: if isSignedIn() && request.auth.token.email.lower() == email;
      allow read, write: if false; // Management via Firebase Console
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isAuthorized();
      // Let them create their basic profile doc
      allow create: if isOwner(userId) && isValidId(userId) && isAuthorized();
      allow update: if isOwner(userId) && isValidId(userId) && isAuthorized();

      // Match all subcollections for the user
      match /agmp_tahun_ajaran/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_kelas/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_siswa/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_tp/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_kktp/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_rubrik/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_jurnal/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_absensi/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_formatif/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_sumatif/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_remedial/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_rapor/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
      match /agmp_anekdot/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(docId);
      }
    }
  }
}
